# Terraform
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/tfplan
# kubeconfig is generated by terraform apply — contains cluster admin credentials
infra/terraform/kubeconfig.yaml

# SOPS — only encrypted files (*.enc.yaml) are committed
# Plain *.yaml in secrets/ must never be committed
infra/secrets/*.yaml
!infra/secrets/*.enc.yaml
!infra/secrets/.gitkeep

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# age private key — must never be committed
keys.txt
age.key

